<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>À propos de l'artiste — Christophe Poly</title>
<meta name="description" content="Découvrez l'histoire de Christophe Poly, artisan bijoutier à Montréal, et le processus de création de son atelier.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  /* ── TOKENS ── */
  :root {
    --amber: #D4920A;
    --amber-lt: #F5C842;
    --amber-pale: #FDF3D8;
    --coal: #1E1C1A;
    --coal-soft: #45413C;
    --paper: #FAF6EF;
    --paper-dk: #F0E9DC;
    --mist: rgba(30, 28, 26, 0.52);
    --line: rgba(30, 28, 26, 0.10);
    --r: 2px;
    --max: 1200px;
  }

  /* ── RESET & BASE ── */
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Inter', sans-serif;
    background: var(--paper);
    color: var(--coal);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  a { text-decoration: none; color: inherit; }
  img { max-width: 100%; display: block; }
  
  h1, h2, h3, h4, .display { font-family: 'Cormorant Garant', serif; font-weight: 500; }
  em { font-style: italic; }

  /* ── SHARED HEADER ── */
  header {
    position: sticky; top: 0; z-index: 100;
    background: var(--paper);
    height: 66px;
    border-bottom: 1px solid var(--line);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 40px;
  }
  .h-left { display: flex; flex-direction: column; }
  .h-left .logo { font-family: 'Cormorant Garant', serif; font-weight: 600; font-size: 1.3rem; line-height: 1; }
  .h-left .subline { font-family: 'Inter', sans-serif; font-weight: 500; text-transform: uppercase; font-size: 0.58rem; color: var(--mist); margin-top: 4px; letter-spacing: 0.05em; }
  
  .h-center { display: flex; gap: 32px; }
  .h-center a { font-size: 0.85rem; transition: color 0.2s; }
  .h-center a:hover { color: var(--amber); }
  .h-center a.active { color: var(--amber); font-weight: 600; }

  .h-right { display: flex; align-items: center; gap: 16px; }
  .h-right .lang { font-size: 0.8rem; font-weight: 600; margin-right: 8px; }
  .btn-etsy, .btn-b2b {
    padding: 8px 16px; font-size: 0.8rem; font-weight: 500;
    border-radius: var(--r); transition: all 0.2s ease;
  }
  .btn-etsy { background: var(--amber); color: #fff; }
  .btn-etsy:hover { background: var(--amber-lt); transform: translateY(-1px); }
  .btn-b2b { background: var(--coal); color: var(--paper); }
  .btn-b2b:hover { background: var(--coal-soft); transform: translateY(-1px); }
  
  .hamburger { display: none; background: none; border: none; font-size: 1.5rem; color: var(--coal); cursor: pointer; }

  /* ── BREADCRUMB ── */
  .breadcrumb {
    max-width: var(--max); margin: 30px auto 0; padding: 0 40px;
    font-size: 0.72rem; color: var(--mist);
  }

  /* ── PAGE HERO (Asymmetric) ── */
  .hero {
    max-width: var(--max); margin: 0 auto; padding: 60px 40px 100px;
    display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 80px; align-items: center;
  }
  .hero-left .eyebrow { 
    display: block; font-size: 0.75rem; font-weight: 600; 
    text-transform: uppercase; color: var(--amber); letter-spacing: 0.1em; 
    margin-bottom: 24px; 
  }
  .hero-left h1 { font-size: clamp(3rem, 5vw, 4.5rem); line-height: 0.95; margin-bottom: 12px; }
  .hero-left .subline { font-family: 'Cormorant Garant', serif; font-size: 2.2rem; color: var(--mist); font-style: italic; display: block; }
  
  .hero-right { position: relative; }
  .portrait-placeholder {
    width: 100%; aspect-ratio: 3/4; background: var(--coal); border-radius: var(--r);
    display: flex; align-items: center; justify-content: center; position: relative;
    overflow: hidden;
  }
  .portrait-placeholder::before {
    content: ''; position: absolute; inset: 20px; border: 1px solid rgba(250, 246, 239, 0.15); border-radius: var(--r);
  }
  .portrait-caption {
    position: absolute; bottom: -30px; right: 0;
    font-size: 0.8rem; color: var(--mist); font-style: italic; font-family: 'Cormorant Garant', serif;
  }

  /* ── L'ARTISTE STORY ── */
  .blade { width: 100%; height: 3px; background: var(--amber); }
  
  .story-section {
    max-width: var(--max); margin: 0 auto; padding: 120px 40px;
    display: grid; grid-template-columns: 0.8fr 1.2fr; gap: 80px; align-items: start;
  }
  .story-image {
    aspect-ratio: 1/1.2; background: var(--paper-dk); border-radius: var(--r);
    display: flex; align-items: center; justify-content: center; position: relative;
  }
  /* Decorative abstract geometry for the placeholder */
  .story-image svg { width: 60%; stroke: var(--coal); stroke-width: 1.5px; opacity: 0.3; }
  
  .story-content p {
    font-size: 1.1rem; line-height: 1.8; color: var(--coal-soft); margin-bottom: 24px;
  }
  .story-content p:first-of-type::first-letter {
    float: left; font-family: 'Cormorant Garant', serif; font-size: 4rem; line-height: 0.8; 
    padding-right: 12px; color: var(--amber); font-weight: 500;
  }

  /* ── L'ATELIER (Process) ── */
  .atelier-section {
    background: var(--coal); color: var(--paper); padding: 120px 0;
  }
  .atelier-head {
    max-width: var(--max); margin: 0 auto; padding: 0 40px; margin-bottom: 60px;
  }
  .atelier-head h2 { font-size: clamp(2rem, 3.5vw, 3rem); line-height: 1.1; color: var(--paper); }
  
  .process-grid {
    max-width: var(--max); margin: 0 auto; padding: 0 40px;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
    background: rgba(250, 246, 239, 0.1); border-top: 1px solid rgba(250, 246, 239, 0.1);
  }
  .process-step { background: var(--coal); padding: 40px 30px 40px 0; }
  .process-step .num {
    font-family: 'Cormorant Garant', serif; font-style: italic; font-size: 1.5rem;
    color: var(--amber); display: block; margin-bottom: 16px; line-height: 1;
  }
  .process-step h3 { font-size: 1.1rem; font-weight: 500; margin-bottom: 12px; font-family: 'Inter', sans-serif; }
  .process-step p { font-size: 0.9rem; color: rgba(250, 246, 239, 0.6); }

  .atelier-address {
    text-align: center; margin-top: 80px; padding: 0 40px;
  }
  .address-pill {
    display: inline-block; background: var(--amber); color: var(--coal);
    padding: 12px 28px; border-radius: 100px; font-weight: 600; font-size: 0.9rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }

  /* ── CONTACT ── */
  .contact-section {
    background: var(--paper-dk); padding: 120px 40px;
  }
  .contact-inner {
    max-width: var(--max); margin: 0 auto;
  }
  .contact-inner h2 {
    font-size: clamp(2rem, 3vw, 2.5rem); margin-bottom: 60px;
  }
  .contact-grid {
    display: grid; grid-template-columns: 1fr 1.5fr; gap: 80px;
  }
  .contact-info { display: flex; flex-direction: column; gap: 30px; }
  .info-card {
    background: var(--paper); padding: 30px; border-radius: var(--r);
    border: 1px solid var(--line);
  }
  .info-card h4 { font-family: 'Inter', sans-serif; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mist); margin-bottom: 12px; }
  .info-card p { font-size: 1rem; color: var(--coal); font-weight: 500; }
  .info-card a { border-bottom: 1px solid transparent; transition: border-color 0.2s; }
  .info-card a:hover { border-color: var(--coal); }

  .contact-cta {
    background: var(--coal); color: var(--paper); padding: 56px 50px;
    border-radius: var(--r); display: flex; flex-direction: column;
    justify-content: center; gap: 22px; position: relative; overflow: hidden;
  }
  .contact-cta::before{
    content:''; position:absolute; inset:0; opacity:.06; pointer-events:none;
    background:
      radial-gradient(circle at 85% 15%, var(--amber) 0%, transparent 45%);
  }
  .contact-cta .eyebrow2 {
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--amber-lt); position: relative;
  }
  .contact-cta h3 {
    font-family: 'Cormorant Garant', serif; font-weight: 500; font-size: 1.9rem; line-height: 1.25;
    max-width: 380px; position: relative;
  }
  .contact-cta p {
    color: rgba(250, 246, 239, 0.6); font-size: 0.92rem; max-width: 380px; position: relative;
  }
  .btn-mail {
    display: inline-flex; align-items: center; gap: 10px; align-self: flex-start;
    background: var(--amber); color: var(--coal); padding: 16px 28px;
    font-size: 0.95rem; font-weight: 600; border-radius: var(--r);
    transition: all 0.2s; position: relative;
  }
  .btn-mail:hover { background: var(--amber-lt); transform: translateY(-1px); }
  .contact-cta .form-note {
    font-size: 0.8rem; color: rgba(250, 246, 239, 0.4); position: relative;
  }

  /* ── SHARED FOOTER ── */
  footer {
    border-top: 3px solid var(--coal);
    background: var(--paper); padding: 80px 40px 30px;
  }
  .footer-grid {
    max-width: var(--max); margin: 0 auto;
    display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px;
  }
  .f-brand .logo { font-family: 'Cormorant Garant', serif; font-size: 1.8rem; font-weight: 500; display: block; margin-bottom: 16px; }
  .f-brand p { color: var(--mist); font-size: 0.9rem; max-width: 280px; margin-bottom: 24px; }
  
  .f-col h4 { font-family: 'Inter', sans-serif; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mist); margin-bottom: 20px; }
  .f-col ul { list-style: none; display: flex; flex-direction: column; gap: 12px; }
  .f-col a { font-size: 0.9rem; color: var(--coal); transition: color 0.2s; }
  .f-col a:hover { color: var(--amber); }

  .footer-bottom {
    max-width: var(--max); margin: 80px auto 0; padding-top: 24px;
    border-top: 1px solid var(--line);
    display: flex; justify-content: space-between; align-items: center;
    font-size: 0.75rem; color: var(--mist);
  }

  /* ── RESPONSIVE (<860px) ── */
  @media (max-width: 860px) {
    .h-center, .h-right .lang, .h-right .btn-etsy, .h-right .btn-b2b { display: none; }
    .hamburger { display: block; }
    
    .hero { grid-template-columns: 1fr; gap: 40px; padding: 40px 20px 80px; }
    .hero-left h1 { font-size: 3.5rem; }
    .hero-left .subline { font-size: 1.8rem; }
    .portrait-caption { bottom: -24px; }
    
    .story-section { grid-template-columns: 1fr; gap: 40px; padding: 80px 20px; }
    .story-image { aspect-ratio: 16/9; }
    
    .atelier-head { padding: 0 20px; margin-bottom: 40px; }
    .process-grid { grid-template-columns: 1fr; gap: 30px; padding: 0 20px; border-top: none; }
    .process-step { padding: 0 0 30px 0; border-bottom: 1px solid rgba(250,246,239,0.1); }
    .process-step:last-child { border-bottom: none; }
    
    .contact-section { padding: 80px 20px; }
    .contact-grid { grid-template-columns: 1fr; gap: 40px; }
    .contact-cta { padding: 40px 28px; }
    
    .footer-grid { grid-template-columns: 1fr; gap: 40px; }
    .footer-bottom { flex-direction: column; gap: 16px; text-align: center; }
  }
</style>
</head>
<body>

  <!-- Header -->
  <header>
    <div class="h-left">
      <a href="index.html" class="logo">Christophe Poly</a>
      <span class="subline">Bijoux artisanaux · Montréal</span>
    </div>
    <nav class="h-center">
      <a href="a-propos.html" class="active">À propos</a>
      <a href="bijoux.html">Bijoux</a>
      <a href="informations.html">Informations</a>
      <a href="expositions.html">Expositions</a>
      <a href="ou-acheter.html">Où acheter</a>
      <a href="#contact">Contact</a>
    </nav>
    <div class="h-right">
      <a href="https://www.etsy.com/shop/ChristophePolyDesign" target="_blank" class="btn-etsy">Boutique Etsy</a>
      <a href="espace-commercant.html" class="btn-b2b">Espace commerçant</a>
      <button class="hamburger" aria-label="Menu">☰</button>
    </div>
  </header>

  <!-- Breadcrumb -->
  <div class="breadcrumb">
    Accueil › À propos
  </div>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-left">
      <span class="eyebrow">L'artiste</span>
      <h1>Christophe Poly</h1>
      <em class="subline">Bijoutier artisan, Montréal</em>
    </div>
    <div class="hero-right">
      <div class="portrait-placeholder">
        <!-- Abstract geometry replacing generic stock photo -->
        <svg viewBox="0 0 100 100" fill="none" style="width:50%; opacity:0.8;">
          <circle cx="50" cy="40" r="15" stroke="var(--amber)" stroke-width="2"/>
          <path d="M20 90 Q 50 60 80 90" stroke="var(--amber)" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
      <span class="portrait-caption">Christophe, en atelier — Montréal</span>
    </div>
  </section>

  <div class="blade"></div>

  <!-- Story -->
  <section class="story-section">
    <div class="story-image">
      <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <rect x="20" y="20" width="160" height="160" rx="4" />
        <line x1="20" y1="100" x2="180" y2="100" />
        <line x1="100" y1="20" x2="100" y2="180" />
        <circle cx="100" cy="100" r="40" stroke="var(--amber)" stroke-width="3" fill="none"/>
      </svg>
    </div>
    <div class="story-content">
      <p>Christophe Poly a une passion pour trouver la beauté dans les objets du quotidien. Il est fasciné par leur volume, leur structure et leur forme. Au fil du temps, il a élaboré un style et une technique novatrice qui lui sont propres.</p>
      <p>Son intérêt pour les voyages, la mode, le design et l'architecture contribue à sa créativité. Chaque saison, les collections sont perfectionnées et de nouveaux designs et catégories sont ajoutés pour surprendre sa clientèle fidèle.</p>
      <p>Ses bijoux peuvent être vus dans de nombreuses galeries, boutiques et musées à travers l'Amérique du Nord. Il est un membre fier et actif du Conseil des métiers d'art du Québec (CMAQ).</p>
    </div>
  </section>

  <!-- Process -->
  <section class="atelier-section">
    <div class="atelier-head">
      <h2>L'atelier</h2>
    </div>
    <div class="process-grid">
      <div class="process-step">
        <span class="num">i</span>
        <h3>Le matériau</h3>
        <p>Aluminium, laiton, acrylique — choisis pour leur volume, leur poids et leur tenue dans le temps.</p>
      </div>
      <div class="process-step">
        <span class="num">ii</span>
        <h3>La découpe</h3>
        <p>Chaque plaque est découpée selon des proportions considérées de la même façon qu'une structure architecturale.</p>
      </div>
      <div class="process-step">
        <span class="num">iii</span>
        <h3>L'assemblage</h3>
        <p>Les éléments sont limés, ajustés et combinés à la main jusqu'à ce que l'équilibre soit parfait.</p>
      </div>
      <div class="process-step">
        <span class="num">iv</span>
        <h3>La finition</h3>
        <p>Chaque pièce est inspectée individuellement avant de recevoir sa finition et de quitter l'atelier.</p>
      </div>
    </div>
    <div class="atelier-address">
      <span class="address-pill">📍 Atelier : 6044 rue St-Hubert, Montréal (QC) H2S 2L7</span>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="contact-section">
    <div class="contact-inner">
      <h2 class="display">Nous contacter</h2>
      <div class="contact-grid">
        <div class="contact-info">
          <div class="info-card">
            <h4>Courriel</h4>
            <p><a href="mailto:info@christophepoly.com">info@christophepoly.com</a></p>
          </div>
          <div class="info-card">
            <h4>Téléphone</h4>
            <p><a href="tel:5142789246">514 278-9246</a><br><a href="tel:18772789246">1 877 278-9246</a> (sans frais)</p>
          </div>
          <div class="info-card">
            <h4>Boutique & Atelier</h4>
            <p>6044 rue St-Hubert<br>Montréal (QC) H2S 2L7</p>
          </div>
          <div class="info-card">
            <h4>Heures d'ouverture</h4>
            <p>Mardi au Samedi : 11h à 17h<br>Dimanche & Lundi : Fermé</p>
          </div>
        </div>
        
        <div class="contact-cta">
          <span class="eyebrow2">Écrivez-nous</span>
          <h3>Une question sur une pièce, une commande ou une visite à l'atelier ?</h3>
          <p>Écrivez-nous directement — nous répondons personnellement à chaque courriel.</p>
          <a href="mailto:info@christophepoly.com" class="btn-mail">
            info@christophepoly.com
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <span class="form-note">Nous répondons généralement dans les 2 jours ouvrables.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="footer-grid">
      <div class="f-brand">
        <span class="logo">Christophe Poly</span>
        <p>Bijoux d'art fait main à Montréal, depuis plus de 30 ans. Membre du CMAQ.</p>
        <div style="display:flex; gap:16px;">
          <a href="#" aria-label="Facebook"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a>
          <a href="https://www.etsy.com/shop/ChristophePolyDesign" target="_blank" aria-label="Etsy"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg></a>
        </div>
      </div>
      <div class="f-col">
        <h4>Explorer</h4>
        <ul>
          <li><a href="a-propos.html">À propos</a></li>
          <li><a href="bijoux.html">Bijoux</a></li>
          <li><a href="expositions.html">Expositions</a></li>
          <li><a href="informations.html">Informations</a></li>
          <li><a href="ou-acheter.html">Où acheter</a></li>
        </ul>
      </div>
      <div class="f-col">
        <h4>Acheter</h4>
        <ul>
          <li><a href="https://www.etsy.com/shop/ChristophePolyDesign" target="_blank">Boutique Etsy</a></li>
          <li><a href="espace-commercant.html">Espace commerçant</a></li>
          <li><a href="ou-acheter.html">Localisateur</a></li>
          <li><a href="expositions.html">Salons</a></li>
        </ul>
      </div>
      <div class="f-col">
        <h4>Contact</h4>
        <ul>
          <li><a href="mailto:info@christophepoly.com">info@christophepoly.com</a></li>
          <li><a href="tel:5142789246">514 278-9246</a></li>
          <li><a href="ou-acheter.html">6044 St-Hubert Mtl</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Christophe Poly · Crono Design Inc.</span>
      <span>Membre du Conseil des métiers d'art du Québec</span>
    </div>
  </footer>

</body>
</html>